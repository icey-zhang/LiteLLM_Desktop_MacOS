{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LiteLLM Desktop",
  "version": "0.1.1",
  "identifier": "ai.litellm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LiteLLM Desktop",
        "width": 900,
        "height": 680,
        "minWidth": 800,
        "minHeight": 580,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["desktop-default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
